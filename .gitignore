# =============================================================================
# Personalized Networking Assistant — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
*.egg-link
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.env.local
.env.production

# -----------------------------------------------------------------------------
# Environment / Secrets — NEVER commit real credentials
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Database files (SQLite)
# -----------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# HuggingFace model cache
# -----------------------------------------------------------------------------
.cache/
huggingface/
*.bin
*.safetensors
*.onnx

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
*.cover
*.log

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Jupyter / Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Frontend / Node (if any future JS tooling is added)
# -----------------------------------------------------------------------------
node_modules/
.npm/

# -----------------------------------------------------------------------------
# Streamlit
# -----------------------------------------------------------------------------
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
# Large binary / browser exports (not part of source)
# -----------------------------------------------------------------------------
*.har
*.html
SkillWallet_files/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
ehthumbs.db
desktop.ini
