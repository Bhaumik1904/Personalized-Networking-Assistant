# =============================================================================
# Personalized Networking Assistant — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Personalized Networking Assistant"
APP_VERSION="1.0.0"
APP_ENV="development"           # development | production
DEBUG=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# For SQLite (default local dev):
DATABASE_URL="sqlite:///./networking_assistant.db"

# For PostgreSQL (production swap):
# DATABASE_URL="postgresql://user:password@localhost:5432/networking_assistant"

# -----------------------------------------------------------------------------
# AI — Google Gemini
# -----------------------------------------------------------------------------
# Obtain your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-2.5-flash"

# Set to true to use Gemini; false falls back to local GPT-2 Small
USE_GEMINI=true

# -----------------------------------------------------------------------------
# AI — Theme Extraction (DistilBERT)
# -----------------------------------------------------------------------------
# HuggingFace model ID for zero-shot classification (runs locally)
ZERO_SHOT_MODEL="typeform/distilbert-base-uncased-mnli"

# Maximum number of themes to extract from an event description
MAX_THEMES=5

# -----------------------------------------------------------------------------
# AI — Conversation Generation (local fallback if USE_GEMINI=false)
# -----------------------------------------------------------------------------
LOCAL_GEN_MODEL="gpt2"
LOCAL_GEN_MAX_NEW_TOKENS=100
LOCAL_GEN_TEMPERATURE=0.85

# -----------------------------------------------------------------------------
# Wikipedia API
# -----------------------------------------------------------------------------
WIKIPEDIA_LANGUAGE="en"
WIKIPEDIA_USER_AGENT="PersonalizedNetworkingAssistant/1.0 (contact@example.com)"
WIKIPEDIA_MAX_SUMMARY_SENTENCES=3

# -----------------------------------------------------------------------------
# FastAPI Backend
# -----------------------------------------------------------------------------
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Allowed CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:8501,http://127.0.0.1:8501"

# -----------------------------------------------------------------------------
# Streamlit Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=8501
API_BASE_URL="http://localhost:8000/api/v1"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"              # json | text
